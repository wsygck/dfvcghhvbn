-- ✨ 消息弹窗卡片堆叠效果
function Library:Notify(Options)
    local TitleText = Options.Title or "系统提示"
    local ContentText = Options.Text or ""
    local ImageId = Options.Image or "" 
    local Duration = Options.Duration or 3
    local TargetY = Options.TargetHeight or 0.85 
    local BgColor = Options.BackgroundColor or Color3.fromRGB(20, 20, 20)
    local StrokeColor = Options.StrokeColor or Color3.fromRGB(150, 150, 150)
    local TextColor = Options.TextColor or Color3.fromRGB(255, 255, 255)

    local totalContentWidth = 0
    local parts = string.split(ContentText, "D")
    for i, partText in ipairs(parts) do
        if partText ~= "" then
            totalContentWidth = totalContentWidth + math.ceil(TextService:GetTextSize(partText, 13, Enum.Font.GothamMedium, Vector2.new(1000, 20)).X) + 6 
        end
        if i < #parts and ImageId ~= "" then
            totalContentWidth = totalContentWidth + 18 + 4
        end
    end
    local finalWidth = math.clamp(totalContentWidth + 24, 250, 500)

    local NotifFrame = Instance.new("Frame", NotifyScreen)
    NotifFrame.Size = UDim2.fromOffset(finalWidth, 65) 
    NotifFrame.Position = UDim2.new(0.5, 0, 1.2, 0) 
    NotifFrame.AnchorPoint = Vector2.new(0.5, 0.5)
    NotifFrame.BackgroundColor3 = BgColor
    NotifFrame.BackgroundTransparency = 0.2 
    NotifFrame.ZIndex = 100
    Instance.new("UICorner", NotifFrame).CornerRadius = UDim.new(0, 10)
    Instance.new("UIStroke", NotifFrame).Color = StrokeColor

    local uiScale = Instance.new("UIScale", NotifFrame)
    uiScale.Scale = 1 

    local VLayout = Instance.new("UIListLayout", NotifFrame)
    VLayout.SortOrder = Enum.SortOrder.LayoutOrder
    VLayout.Padding = UDim.new(0, 6)
    VLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    Instance.new("UIPadding", NotifFrame).PaddingTop = UDim.new(0, 10)
    Instance.new("UIPadding", NotifFrame).PaddingBottom = UDim.new(0, 10)

    local TitleLbl = Instance.new("TextLabel", NotifFrame)
    TitleLbl.LayoutOrder = 1 TitleLbl.Size = UDim2.new(1, 0, 0, 16) TitleLbl.BackgroundTransparency = 1 TitleLbl.Text = TitleText TitleLbl.Font = Enum.Font.GothamBold TitleLbl.TextSize = 14 TitleLbl.TextColor3 = TextColor TitleLbl.TextXAlignment = Enum.TextXAlignment.Center TitleLbl.ZIndex = NotifFrame.ZIndex + 1

    local ContentContainer = Instance.new("Frame", NotifFrame)
    ContentContainer.LayoutOrder = 2 ContentContainer.Size = UDim2.new(1, 0, 0, 20) ContentContainer.BackgroundTransparency = 1 ContentContainer.ZIndex = NotifFrame.ZIndex + 1
    local HLayout = Instance.new("UIListLayout", ContentContainer)
    HLayout.FillDirection = Enum.FillDirection.Horizontal HLayout.SortOrder = Enum.SortOrder.LayoutOrder HLayout.VerticalAlignment = Enum.VerticalAlignment.Center HLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center HLayout.Padding = UDim.new(0, 4)

    for i, partText in ipairs(parts) do
        if partText ~= "" then
            local textWidth = math.ceil(TextService:GetTextSize(partText, 13, Enum.Font.GothamMedium, Vector2.new(1000, 20)).X) + 2
            local txt = Instance.new("TextLabel", ContentContainer)
            txt.BackgroundTransparency = 1 
            txt.Text = partText 
            txt.Font = Enum.Font.GothamMedium 
            txt.TextSize = 13 
            txt.TextColor3 = TextColor 
            txt.TextWrapped = false 
            txt.Size = UDim2.new(0, textWidth, 1, 0) 
            txt.ZIndex = NotifFrame.ZIndex + 1
        end
        if i < #parts and ImageId ~= "" then
            local img = Instance.new("ImageLabel", ContentContainer)
            img.BackgroundTransparency = 1 img.Image = ImageId img.Size = UDim2.fromOffset(18, 18) img.ZIndex = NotifFrame.ZIndex + 1
        end
    end

    table.insert(Library.ActiveNotifications, 1, NotifFrame)

    local function UpdateNotifications()
        for i = #Library.ActiveNotifications, 1, -1 do
            local frame = Library.ActiveNotifications[i]
            if frame and frame.Parent then
                if i > 4 then
                    frame:Destroy() table.remove(Library.ActiveNotifications, i)
                else
                    local yOffset = (i - 1) * 14 
                    local targetScale = 1 - ((i - 1) * 0.05) 
                    local targetTrans = 0.2 + ((i - 1) * 0.2) 
                    
                    frame.ZIndex = 100 - i 
                    
                    TweenService:Create(frame, TweenInfo.new(0.35, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), { 
                        Position = UDim2.new(0.5, 0, TargetY, -yOffset), 
                        BackgroundTransparency = targetTrans 
                    }):Play()
                    
                    local scaleObj = frame:FindFirstChild("UIScale")
                    if scaleObj then 
                        TweenService:Create(scaleObj, TweenInfo.new(0.35, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), { 
                            Scale = targetScale 
                        }):Play() 
                    end
                end
            end
        end
    end

    UpdateNotifications()

    task.delay(Duration, function()
        local index = table.find(Library.ActiveNotifications, NotifFrame)
        if index then table.remove(Library.ActiveNotifications, index) UpdateNotifications() end
        local slideDown = TweenService:Create(NotifFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.In), { Position = UDim2.new(0.5, 0, 1.2, 0), BackgroundTransparency = 1 })
        slideDown:Play() slideDown.Completed:Connect(function() if NotifFrame then NotifFrame:Destroy() end end)
    end)
end

-- ✨ 最重要的一步：将 Library 抛出，供主脚本调用
return Library
